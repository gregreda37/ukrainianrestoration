rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true if the caller is an admin of orgId.
    // Org owners (uid == orgId) always qualify.
    // Contractors with role == 'admin' also qualify.
    function isOrgAdmin(orgId) {
      return request.auth.uid == orgId ||
        (exists(/databases/$(database)/documents/organization_data/$(orgId)/contractors/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/organization_data/$(orgId)/contractors/$(request.auth.uid)).data.role == 'admin');
    }

    // True when the write touches integration-only fields that only admins may set.
    function touchesIntegrationFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['companyCamAPI', 'googleDriveConnected', 'googleDriveFolderName']);
    }

    // ── Per-user data ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── Organization data ────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read, write: if request.auth != null;
    }

    // OAuth tokens — backend (Admin SDK) only; block all client reads/writes
    match /organization_data/{orgId}/integrations/{intId} {
      allow read, write: if false;
    }

    // Org root doc: anyone in the org may read; writes that touch integration
    // fields require admin. Other writes (e.g. createdAt) are open.
    match /organization_data/{orgId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (!touchesIntegrationFields() || isOrgAdmin(orgId));
    }

    match /organization_data/{orgId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── Client phone / claim lookup ──────────────────────────────────────────
    match /client_phones/{phone} {
      // The doc itself is readable by anyone (login page needs to look up orgId)
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /client_phones/{phone}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── Invite cross-reference ───────────────────────────────────────────────
    match /user_invites/{encodedEmail} {
      allow read, write: if request.auth != null;
    }

    // ── SMS opt-in consent records ────────────────────────────────────────────
    // Written before auth completes (when user clicks "Send Code"), so writes
    // must be allowed unauthenticated. Reads restricted to authenticated users.
    match /opt_in_records/{phone} {
      allow write: if true;
      allow read:  if request.auth != null;
    }

  }
}
