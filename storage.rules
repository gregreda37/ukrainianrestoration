rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User documents — any authenticated user can read and write
    // (contractors need to upload files on behalf of clients)
    match /users/{userId}/documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Pre-login client documents — uploaded by contractors before the client
    // has a Firebase Auth account. Stored per org+client until uid is known.
    match /org_clients/{orgId}/{clientDocId}/documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Org assets — authenticated users can read; only the logo path is writable by auth'd users
    match /organizations/{orgId}/logo/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /organizations/{orgId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Sign requests (PDFs uploaded by contractors to be signed)
    match /users/{userId}/sign-requests/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Signed documents (uploaded by backend, readable by any auth'd user)
    match /signed-documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

  }
}
